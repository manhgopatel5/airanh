rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ================= HELPERS ================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn()
        && request.auth.uid == userId;
    }

    function chatDoc(chatId) {
      return get(
        /databases/$(database)/documents/chats/$(chatId)
      );
    }

    function isChatMember(chatId) {
      return isSignedIn()
        && request.auth.uid in chatDoc(chatId).data.members;
    }

    function isDeletedFor(chatId) {
      return (
        'deletedFor' in chatDoc(chatId).data
        && request.auth.uid
          in chatDoc(chatId).data.deletedFor
      );
    }

    function isBlocked(chatId) {
      return (
        'blockedUsers' in chatDoc(chatId).data
        && request.auth.uid
          in chatDoc(chatId).data.blockedUsers
      );
    }

    function isChatActive(chatId) {
      return !(
        'status' in chatDoc(chatId).data
      )
      || chatDoc(chatId).data.status == 'active';
    }

    /* ================= USERS ================= */

    match /users/{userId} {

      allow read: if isSignedIn();

      allow create, update, delete: if isOwner(userId);

      match /friends/{friendId} {

        allow read: if isOwner(userId);

        allow create: if false;

        allow update: if isSignedIn()
          && request.resource.data
            .diff(resource.data)
            .changedKeys()
            .hasOnly([
              'status',
              'removedAt',
              'updatedAt',
              'removedBy'
            ]);

        allow delete: if isOwner(userId);
      }
    }

    /* ================= CHATS ================= */

    match /chats/{chatId} {

      // query chats realtime
      allow list: if isSignedIn();

      // mở chat
      allow get: if isChatMember(chatId);

      // tạo chat mới
      allow create: if isSignedIn()
        && request.auth.uid
          in request.resource.data.members;

      // update metadata
      allow update: if isChatMember(chatId)
        && request.resource.data
          .diff(resource.data)
          .changedKeys()
          .hasOnly([
            'deletedFor',
            'updatedAt',
            'typing',
            'pinnedMessage',
            'members',
            'lastMessage',
            'lastSenderId',
            'lastSenderName',
            'unread'
          ]);

      allow delete: if false;

      /* ================= MESSAGES ================= */

      match /messages/{messageId} {

        // realtime messages query
        allow get, list: if isChatMember(chatId)
          && !isDeletedFor(chatId);

        // gửi tin
        allow create: if isSignedIn()
          && request.auth.uid
            == request.resource.data.senderId
          && isChatMember(chatId)
          && isChatActive(chatId)
          && !isBlocked(chatId);

        // seen / react / edit
        allow update: if isChatMember(chatId)
          && (
            (
              resource.data.senderId
                == request.auth.uid
              && request.resource.data
                .diff(resource.data)
                .changedKeys()
                .hasOnly([
                  'text',
                  'edited',
                  'editedAt',
                  'reactions',
                  'seenBy'
                ])
            )
            ||
            (
              request.resource.data
                .diff(resource.data)
                .changedKeys()
                .hasOnly([
                  'seenBy',
                  'reactions'
                ])
            )
          );

        // xóa tin nhắn của mình
        allow delete: if isSignedIn()
          && resource.data.senderId
            == request.auth.uid;
      }
    }

    /* ================= FRIEND REQUESTS ================= */

    match /friendRequests/{reqId} {

      allow read: if isSignedIn()
        && (
          request.auth.uid
            == resource.data.from
          || request.auth.uid
            == resource.data.to
        );

      allow create: if isSignedIn()
        && request.auth.uid
          == request.resource.data.from;

      allow delete: if isSignedIn()
        && (
          request.auth.uid
            == resource.data.from
          || request.auth.uid
            == resource.data.to
        );
    }

    /* ================= USERNAMES ================= */

    match /usernames/{username} {

      allow read: if true;

      allow write: if false;
    }

    /* ================= NOTIFICATIONS ================= */

    match /notifications/{userId}/items/{notifId} {

      allow read: if isOwner(userId);

      allow create: if isSignedIn();

      allow update: if isOwner(userId);

      allow delete: if isOwner(userId);
    }
  }
}
