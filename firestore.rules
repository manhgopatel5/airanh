rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth!= null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email in ['justastormyday@gmail.com', 'hongann2210@gmail.com'];
    }
    function isPublic(chatId) { return chatId.matches('public_.*'); }

   // ========== ADMIN CREDENTIALS ==========
match /admin_credentials/{docId} {
  allow read: if true;
  allow write: if false;
}

match /users/{userId} {
  allow read: if true;

  allow update: if isOwner(userId)
    &&!request.resource.data.diff(resource.data).changedKeys().hasAny(['vip', 'role', 'banned'])
    && request.resource.data.diff(resource.data).changedKeys()
   .hasOnly(['name', 'avatar', 'bio', 'birthday', 'phone', 'title', 'location',
               'skills', 'portfolio', 'online', 'lastSeen', 'nameLower', 'huhaScore', 'fcmToken', 'friendCount']);

  allow create: if isOwner(userId);
  allow delete: if isAdmin();

  match /friends/{friendId} {
    allow read: if isOwner(userId);
    allow write: if isOwner(userId);
  }
}

// ========== FRIENDS COLLECTION GỐC ==========
match /friends/{friendId} {
  allow list: if isSignedIn() && request.auth.uid == request.query.where[0][2];
  allow get: if isSignedIn() && request.auth.uid in friendId.split('_');
  allow create: if isSignedIn() &&
    request.auth.uid == request.resource.data.userId &&
    friendId == request.resource.data.userId + '_' + request.resource.data.friendId &&
    request.resource.data.keys().hasAll(['userId', 'friendId', 'createdAt']);
  allow update: if isSignedIn() &&
    request.auth.uid == resource.data.userId &&
    request.resource.data.diff(resource.data).changedKeys()
   .hasOnly(['lastInteractionAt', 'updatedAt', 'status', 'removedAt', 'removedBy']);
  allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
}

    // ========== BLOCKS ==========
    match /blocks/{blockId} {
      allow read: if isSignedIn() && request.auth.uid in blockId.split('_');
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.fromUserId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.fromUserId;
    }

    // ========== EVENTS ==========
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /promoCodes/{code} {
      allow read: if false;
      allow write: if false;
    }

    // ========== CHECKINS ==========
    match /checkins/{checkinId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ========== PROVINCES ==========
    match /provinces/{provinceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ========== SESSIONS ==========
    match /sessions/{sessionId} {
      allow get: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow list: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.keys().hasAll(['uid', 'device', 'browser', 'os', 'ip', 'location', 'userAgent', 'current', 'lastActive', 'createdAt'])
        && request.resource.data.current is bool
        && request.resource.data.uid is string;
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).changedKeys()
     .hasOnly(['lastActive', 'current', 'ip', 'location', 'browser', 'os', 'userAgent', 'device']);
      allow delete: if isSignedIn() && request.auth.uid == resource.data.uid;
    }

    // ========== TASKS + COMMENTS ==========
    match /tasks/{taskId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).changedKeys()
     .hasOnly(['savedBy', 'likedBy', 'likeCount', 'commentCount', 'applicants', 'appliedCount', 'hotScore'])
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update: if isSignedIn() && (
          (
            request.auth.uid == resource.data.userId &&
            request.resource.data.diff(resource.data).changedKeys()
         .hasOnly(['text', 'edited', 'updatedAt'])
          ) ||
          (
            request.resource.data.diff(resource.data).changedKeys()
         .hasOnly(['likeCount', 'likedBy'])
          ) ||
          (
            request.auth.uid == resource.data.userId &&
            request.resource.data.diff(resource.data).changedKeys()
         .hasOnly(['deleted', 'text', 'updatedAt']) &&
            request.resource.data.deleted == true
          ) ||
          (
            resource.data.parentId!= null &&
            get(/databases/$(database)/documents/tasks/$(taskId)/comments/$(resource.data.parentId)).data.userId == request.auth.uid &&
            request.resource.data.diff(resource.data).changedKeys()
         .hasOnly(['deleted', 'text', 'updatedAt']) &&
            request.resource.data.deleted == true
          )
        );
        allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      }
    }

    // ========== APPLICATIONS ==========
    match /applications/{appId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'taskOwnerId', 'status', 'userName'])
        && request.resource.data.status == 'pending';
      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.userId &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt']) &&
        request.resource.data.status == 'cancelled') ||
        (request.auth.uid == resource.data.taskOwnerId &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt']) &&
        request.resource.data.status in ['accepted', 'rejected'])
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /task_likes/{likeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /task_participants/{participantId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /shortIds/{shortId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ========== GROUPS ==========
    match /groups/{groupId} {
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.members ||
        request.auth.uid == resource.data.ownerId ||
        request.query.where.groupCode!= null
      );
      allow list: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll([
          'name', 'groupCode', 'members', 'admins', 'ownerId',
          'createdBy', 'createdAt', 'updatedAt', 'isGroup',
          'memberCount', 'hasPassword'
        ])
        && request.auth.uid == request.resource.data.ownerId
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == 1
        && request.resource.data.memberCount == 1
        && request.resource.data.isGroup == true
        && request.resource.data.groupCode is string
        && request.resource.data.groupCode.matches('^[0-9]{6}$')
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 3
        && request.resource.data.hasPassword is bool
        && (!request.resource.data.hasPassword || request.resource.data.passwordHash is string);
      allow update: if isSignedIn() && (
        request.auth.uid in resource.data.admins ||
        request.auth.uid == resource.data.createdBy ||
        (
          request.auth.uid in request.resource.data.members &&
          request.resource.data.diff(resource.data).changedKeys()
           .hasOnly(['members', 'memberCount', 'unreadCount', 'lastMessage', 'lastSenderId', 'updatedAt', 'seen', 'typing'])
        )
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.senderId
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members;
        allow update: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.members
          && request.resource.data.diff(resource.data).changedKeys()
           .hasOnly(['seenBy', 'reactions', 'text', 'editedAt', 'edited']);
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    // ========== CHATS ==========
    match /chats/{chatId} {
      allow read: if isSignedIn() && (isPublic(chatId) || request.auth.uid in resource.data.members);
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.members
        && (isPublic(chatId) || request.resource.data.members.size() >= 2);
      allow update: if isSignedIn() && (isPublic(chatId) || request.auth.uid in resource.data.members);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          isPublic(chatId) ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
        );
        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.senderId
          && (
            isPublic(chatId) ||
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          )
          && get(/databases/$(database)/documents/chats/$(chatId)).data.get('status', 'active') == 'active'
          &&!(request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('blockedUsers', []));
        allow update: if isSignedIn()
          && (
            isPublic(chatId) ||
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          )
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'seenBy', 'reactions', 'text', 'editedAt', 'edited', 'pollData'
          ])
          && (
            request.resource.data.senderId == request.auth.uid ||
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['seenBy', 'reactions', 'pollData'])
          );
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

   // ========== FRIEND REQUESTS - FIX LỖI PERMISSION ==========
match /friendRequests/{reqId} {
  // QUAN TRỌNG: Bỏ check where, chỉ cần login là cho list
  allow list: if isSignedIn();

  allow get: if isSignedIn() &&
    (request.auth.uid == resource.data.fromUserId ||
     request.auth.uid == resource.data.toUserId);

  allow create: if isSignedIn()
    && request.auth.uid == request.resource.data.fromUserId
    && request.resource.data.toUserId is string
    && request.resource.data.status == 'pending'
    && request.resource.data.createdAt is timestamp;

  allow update: if isSignedIn() &&
    (request.auth.uid == resource.data.toUserId || request.auth.uid == resource.data.fromUserId)
    && request.resource.data.diff(resource.data).changedKeys()
.hasOnly(['status', 'updatedAt', 'respondedAt']);

  allow delete: if isSignedIn() &&
    (request.auth.uid == resource.data.fromUserId || request.auth.uid == resource.data.toUserId);
}

    // ========== USERNAMES ==========
    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'createdAt'])
        &&!exists(/databases/$(database)/documents/usernames/$(username));
      allow update, delete: if false;
    }

    match /notifications/{userId}/items/{notifId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    // ========== STRANGER CHAT ==========
    match /stranger_chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if false;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.members
        && request.resource.data.diff(resource.data).changedKeys()
         .hasOnly([
            'messages', 'lastMessageTime', 'status',
            'endedAt', 'extended', 'expiresAt', 'reportedBy',
            'unreadCounts', 'onlineStatus', 'partnerNames', 'partnerAvatars',
            'members', 'lastMessage', 'friendRequests', 'filters'
          ]);
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/stranger_chats/$(chatId)).data.members;
        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.senderId
          && request.auth.uid in get(/databases/$(database)/documents/stranger_chats/$(chatId)).data.members
          && get(/databases/$(database)/documents/stranger_chats/$(chatId)).data.status == 'active';
        allow update: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/stranger_chats/$(chatId)).data.members
          && request.resource.data.diff(resource.data).changedKeys()
           .hasOnly(['seenBy', 'reactions', 'text', 'editedAt', 'edited']);
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    // ========== STRANGER QUEUE ==========
    match /stranger_queue/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOwner(userId);
    }

    // ========== ORDERS ==========
    match /orders/{orderId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        isAdmin()
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if false;
    }

    // ========== PLANS ==========
    match /plans/{planId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ========== REPORTS ==========
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}