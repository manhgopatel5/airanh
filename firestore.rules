rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* ================= HELPERS ================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn()
        && request.auth.uid == userId;
    }

    /* ================= USERS ================= */

    match /users/{userId} {

      allow read: if isSignedIn();

      allow create, update, delete: if isOwner(userId);

      match /friends/{friendId} {

        allow read: if isOwner(userId);

        allow create: if false;

        allow update: if isSignedIn()
          && request.resource.data
            .diff(resource.data)
            .changedKeys()
            .hasOnly([
              'status',
              'removedAt',
              'updatedAt',
              'removedBy'
            ]);

        allow delete: if isOwner(userId);
      }
    }

    /* ================= CHATS ================= */

    match /chats/{chatId} {

      // realtime chats query
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.members;

      // tạo chat
      allow create: if isSignedIn()
        && request.auth.uid
          in request.resource.data.members;

      // update chat
      allow update: if isSignedIn()
        && request.auth.uid
          in resource.data.members;

      allow delete: if false;

      /* ================= MESSAGES ================= */

      match /messages/{messageId} {

        // realtime messages
        allow read: if isSignedIn()
          && request.auth.uid in get(
            /databases/$(database)/documents/chats/$(chatId)
          ).data.members;

        // gửi tin
        allow create: if isSignedIn()
          && request.auth.uid
            == request.resource.data.senderId;

        // seen/react/edit
        allow update: if isSignedIn()
          && request.auth.uid in get(
            /databases/$(database)/documents/chats/$(chatId)
          ).data.members;

        // xóa tin nhắn của mình
        allow delete: if isSignedIn()
          && resource.data.senderId
            == request.auth.uid;
      }
    }

    /* ================= FRIEND REQUESTS ================= */

    match /friendRequests/{reqId} {

      allow read: if isSignedIn()
        && (
          request.auth.uid
            == resource.data.from
          || request.auth.uid
            == resource.data.to
        );

      allow create: if isSignedIn()
        && request.auth.uid
          == request.resource.data.from;

      allow delete: if isSignedIn()
        && (
          request.auth.uid
            == resource.data.from
          || request.auth.uid
            == resource.data.to
        );
    }

    /* ================= USERNAMES ================= */

    match /usernames/{username} {

      allow read: if true;

      allow write: if false;
    }

    /* ================= NOTIFICATIONS ================= */

    match /notifications/{userId}/items/{notifId} {

      allow read: if isOwner(userId);

      allow create: if isSignedIn();

      allow update: if isOwner(userId);

      allow delete: if isOwner(userId);
    }
  }
}
