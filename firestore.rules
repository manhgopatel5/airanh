rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow create: if false;
        allow update: if isSignedIn() 
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'removedAt', 'updatedAt']);
        allow delete: if isOwner(userId);
      }
    }

    // ========== TASKS + COMMENTS ==========
    match /tasks/{taskId} {
      allow read: if true;
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        // Chủ task sửa được hết
        request.auth.uid == resource.data.userId ||
        // User khác chỉ được like + save, KHÔNG được ứng tuyển trực tiếp vào tasks nữa
        request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['savedBy', 'likedBy', 'likeCount'])
      );
      
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;

      // COMMENTS
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update: if isSignedIn() 
          && request.auth.uid == resource.data.userId
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['text', 'edited', 'updatedAt', 'likeCount', 'likedBy']);
        allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      }
    }

    // ========== APPLICATIONS - THÊM MỚI ==========
    match /applications/{appId} {
      // Ứng viên và chủ task đều đọc được
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        request.auth.uid == resource.data.taskOwnerId
      );
      
      // Chỉ user mới tạo đơn ứng tuyển cho chính mình
      allow create: if isSignedIn() 
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'taskOwnerId', 'status', 'userName'])
        && request.resource.data.status == 'pending';
      
      // Ứng viên hủy đơn hoặc chủ task duyệt/từ chối
      allow update: if isSignedIn() && (
        // Ứng viên tự hủy
        request.auth.uid == resource.data.userId && 
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt']) &&
        request.resource.data.status == 'cancelled' ||
        // Chủ task duyệt/từ chối
        request.auth.uid == resource.data.taskOwnerId &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt']) &&
        request.resource.data.status in ['accepted', 'rejected']
      );
      
      // Ứng viên xóa đơn của mình
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /task_likes/{likeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /task_participants/{participantId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /shortIds/{shortId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /chats/{chatId} {
      allow get: if isSignedIn() && request.auth.uid in resource.data.members;
      
      allow list: if isSignedIn() 
        && request.auth.uid in resource.data.members
        && !(request.auth.uid in resource.data.get('deletedFor', []))
        && resource.data.get('status', 'active') == 'active';
      
      allow create: if false;
      
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.members;
      
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() 
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          && !(request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('deletedFor', []));
        
        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.senderId
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          && get(/databases/$(database)/documents/chats/$(chatId)).data.get('status', 'active') == 'active'
          && !(request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('blockedUsers', []));
        
        allow update: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'seenBy', 'reactions', 'text', 'editedAt', 'edited'
          ])
          && (request.resource.data.senderId == request.auth.uid || request.resource.data.diff(resource.data).changedKeys().hasOnly(['seenBy', 'reactions']));
        
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    match /friendRequests/{reqId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.from;
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }

    match /usernames/{username} {
      allow read: if true;
      allow write: if false;
    }

    match /notifications/{userId}/items/{notifId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn();
      allow delete: if isOwner(userId);
      allow update: if isOwner(userId);
    }
  }
}