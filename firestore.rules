rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth!= null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() {
      return isSignedIn() &&
             request.auth.token.email in ['justastormyday@gmail.com', 'hongann2210@gmail.com'];
    }

    // ========== ADMIN CREDENTIALS ==========
    match /admin_credentials/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ========== USERS + SUBCOLLECTION FRIENDS ==========
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      match /friends/{friendId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // ========== EVENTS ==========
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ========== PROVINCES ==========
    match /provinces/{provinceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ========== PUBLIC ROOMS ==========
    match /public_rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin(); // Chỉ admin sửa trên console
    }

    // ========== SESSIONS ==========
    match /sessions/{sessionId} {
      allow get: if isSignedIn() && request.auth.uid == resource.data.uid;
      allow list: if isSignedIn() && request.auth.uid == resource.data.uid;

      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.keys().hasAll(['uid', 'device', 'browser', 'os', 'ip', 'location', 'userAgent', 'current', 'lastActive', 'createdAt'])
        && request.resource.data.current is bool
        && request.resource.data.uid is string;

      allow update: if isSignedIn()
        && request.auth.uid == resource.data.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).changedKeys()
.hasOnly(['lastActive', 'current', 'ip', 'location', 'browser', 'os', 'userAgent', 'device']);

      allow delete: if isSignedIn() && request.auth.uid == resource.data.uid;
    }

    // ========== TASKS + COMMENTS ==========
    match /tasks/{taskId} {
      allow read: if true;
      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).changedKeys()
.hasOnly(['savedBy', 'likedBy', 'likeCount', 'commentCount', 'applicants', 'appliedCount'])
      );

      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn();

        allow update: if isSignedIn() && (
          (
            request.auth.uid == resource.data.userId &&
            request.resource.data.diff(resource.data).changedKeys()
    .hasOnly(['text', 'edited', 'updatedAt'])
          ) ||
          (
            request.resource.data.diff(resource.data).changedKeys()
    .hasOnly(['likeCount', 'likedBy'])
          ) ||
          (
            request.auth.uid == resource.data.userId &&
            request.resource.data.diff(resource.data).changedKeys()
    .hasOnly(['deleted', 'text', 'updatedAt']) &&
            request.resource.data.deleted == true
          ) ||
          (
            resource.data.parentId!= null &&
            get(/databases/$(database)/documents/tasks/$(taskId)/comments/$(resource.data.parentId)).data.userId == request.auth.uid &&
            request.resource.data.diff(resource.data).changedKeys()
    .hasOnly(['deleted', 'text', 'updatedAt']) &&
            request.resource.data.deleted == true
          )
        );

        allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
      }
    }

    // ========== APPLICATIONS ==========
    match /applications/{appId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'taskOwnerId', 'status', 'userName'])
        && request.resource.data.status == 'pending';

      allow update: if isSignedIn() && (
        (request.auth.uid == resource.data.userId &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt']) &&
        request.resource.data.status == 'cancelled') ||
        (request.auth.uid == resource.data.taskOwnerId &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'updatedAt']) &&
        request.resource.data.status in ['accepted', 'rejected'])
      );

      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    match /task_likes/{likeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /task_participants/{participantId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /shortIds/{shortId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ========== CHATS - PHÒNG CÔNG CỘNG TỰ DO ĐỌC/GHI ==========
    match /chats/{chatId} {
      // Đọc: phòng công cộng thì login là đọc được, không cần members
      allow get, list: if isSignedIn() && (
        resource.data.get('isPublicRoom', false) == true ||
        request.auth.uid in resource.data.get('members', [])
      );

      // Tạo: cho phép client tự tạo phòng công cộng lần đầu
      allow create: if isSignedIn() && (
        // Phòng riêng: phải có ít nhất 2 members và mình nằm trong đó
        (!request.resource.data.get('isPublicRoom', false) && 
         request.auth.uid in request.resource.data.get('members', []) &&
         request.resource.data.get('members', []).size() >= 2) ||
        // Phòng công cộng: cho tạo với chatId = public_*
        (request.resource.data.get('isPublicRoom', false) == true &&
         chatId.matches('public_.*') &&
         request.resource.data.keys().hasAll(['isGroup', 'isPublicRoom', 'status', 'groupName', 'members']) &&
         request.resource.data.isGroup == true &&
         request.resource.data.status == 'active')
      );

      // Update: phòng công cộng cho update lastMessage, lastMessageTime, updatedAt. Không cho sửa members/isPublicRoom
      allow update: if isSignedIn() && (
        // Phòng riêng: phải trong members
        (!resource.data.get('isPublicRoom', false) && request.auth.uid in resource.data.get('members', [])) ||
        // Phòng công cộng: chỉ cho update 3 field này
        (resource.data.get('isPublicRoom', false) == true && 
         request.resource.data.diff(resource.data).changedKeys().hasOnly(['lastMessage', 'lastMessageTime', 'updatedAt']))
      );

      allow delete: if false;

      match /messages/{messageId} {
        // Đọc: login là đọc được nếu là phòng công cộng
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/chats/$(chatId)).data.get('isPublicRoom', false) == true ||
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('members', [])
        );

        // Gửi tin: login + phòng active + không bị block. Phòng công cộng không cần members
        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.senderId
          && get(/databases/$(database)/documents/chats/$(chatId)).data.get('status', 'active') == 'active'
          && (
            // Phòng công cộng: ai login cũng gửi được
            get(/databases/$(database)/documents/chats/$(chatId)).data.get('isPublicRoom', false) == true ||
            // Phòng riêng: phải trong members
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('members', [])
          )
          &&!(request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('blockedUsers', []));

        // Update: seen, reaction, edit text của mình
        allow update: if isSignedIn()
          && (
            get(/databases/$(database)/documents/chats/$(chatId)).data.get('isPublicRoom', false) == true ||
            request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('members', [])
          )
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'seenBy', 'reactions', 'text', 'editedAt', 'edited', 'pollData'
          ])
          && (
            request.resource.data.senderId == request.auth.uid ||
            request.resource.data.diff(resource.data).changedKeys().hasOnly(['seenBy', 'reactions', 'pollData'])
          );

        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    // ========== FRIEND REQUESTS ==========
    match /friendRequests/{reqId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.fromUserId
            || request.auth.uid == resource.data.toUserId);

      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.fromUserId
        && request.resource.data.toUserId is string
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt is timestamp;

      allow update: if isSignedIn()
        && (request.auth.uid == resource.data.fromUserId
            || request.auth.uid == resource.data.toUserId)
        && request.resource.data.diff(resource.data).changedKeys()
     .hasOnly(['status', 'updatedAt']);

      allow delete: if isSignedIn()
        && (request.auth.uid == resource.data.fromUserId
            || request.auth.uid == resource.data.toUserId);
    }

    // ========== USERNAMES ==========
    match /usernames/{username} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'createdAt'])
        &&!exists(/databases/$(database)/documents/usernames/$(username));

      allow update, delete: if false;
    }

    match /notifications/{userId}/items/{notifId} {
      allow read: if isOwner(userId);
      allow create: if isSignedIn();
      allow delete: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    // ========== STRANGER CHAT ==========
    match /stranger_chats/{chatId} {
      allow read: if isSignedIn()
        && request.auth.uid in resource.data.get('members', []);
      allow create: if false;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.get('members', [])
        && request.resource.data.diff(resource.data).changedKeys()
.hasOnly(['messages', 'extended', 'expiresAt', 'reportedBy']);
      allow delete: if false;
    }

    // ========== STRANGER QUEUE ==========
    match /stranger_queue/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
  }
}