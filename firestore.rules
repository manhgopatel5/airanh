rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      match /friends/{friendId} {
        // Đọc: chỉ chủ sở hữu đọc được list bạn của mình
        allow read: if isOwner(userId);
        
        // Tạo: chỉ tạo qua Cloud Functions acceptFriendRequest
        allow create: if false;
        
        // Update: cho phép function update status = "removed" khi bị hủy kết bạn
        allow update: if isSignedIn() 
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status', 'removedAt', 'updatedAt']);
        
        // Delete: cho phép tự xóa bạn của mình
        allow delete: if isOwner(userId);
      }

      // Bỏ collection chats con trong users đi, dùng collection chats gốc thôi
      // match /chats/{chatId} { ... } -> xóa đoạn này
    }

    match /chats/{chatId} {
      // GET: cho phép member xem để vào chat ngay cả khi đã xóa/archived
      allow get: if isSignedIn() && request.auth.uid in resource.data.members;
      
      // LIST: ẩn nếu user nằm trong deletedFor HOẶC chat đã archived
      allow list: if isSignedIn() 
        && request.auth.uid in resource.data.members
        && !(request.auth.uid in resource.data.get('deletedFor', []))
        && resource.data.get('status', 'active') != 'archived';
      
      // CREATE: chỉ qua Functions
      allow create: if false;
      
      // UPDATE: cho update settings cá nhân HOẶC gửi tin nếu chat active + không bị block
      allow update: if isSignedIn() 
        && request.auth.uid in resource.data.members
        && (
          // Cho phép update các field cá nhân: deletedFor, archivedBy, mutedBy, typing, unread
          request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['deletedFor', 'archivedBy', 'mutedBy', 'typing', 'unread', 'updatedAt', 'lastMessage', 'lastSenderId', 'lastSenderName'])
          ||
          // Hoặc update khác nếu chat active + không bị block
          (
            resource.data.get('status', 'active') == 'active'
            && !(request.auth.uid in resource.data.get('blockedUsers', []))
          )
        );
      
      allow delete: if false;

      match /messages/{messageId} {
        // READ: cho phép nếu là member và không nằm trong deletedFor
        allow read: if isSignedIn() 
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          && !(request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('deletedFor', []));
        
        // CREATE: chỉ khi chat active + là member + không bị block
        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.senderId
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          && get(/databases/$(database)/documents/chats/$(chatId)).data.get('status', 'active') == 'active'
          && !(request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.get('blockedUsers', []));
        
        // UPDATE: chỉ update seenBy, reactions, edit tin của mình
        allow update: if isSignedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'seenBy', 'reactions', 'text', 'editedAt', 'edited'
          ])
          && (request.resource.data.senderId == request.auth.uid || request.resource.data.diff(resource.data).changedKeys().hasOnly(['seenBy', 'reactions']));
        
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }

    match /friendRequests/{reqId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.from;
      allow delete: if isSignedIn() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }

    match /usernames/{username} {
      allow read: if true;
      allow write: if false;
    }

    match /notifications/{userId}/items/{notifId} {
      allow read: if isOwner(userId);
      // Cho phép function tạo thông báo
      allow create: if isSignedIn();
      // Cho phép user xóa thông báo của mình
      allow delete: if isOwner(userId);
      allow update: if false;
    }
  }
}