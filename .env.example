# Copy to .env.local and fill values. On Vercel: add each variable separately (use = not :).

# Firebase Client
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
# Web Push — Firebase Console → Project Settings → Cloud Messaging → Web Push certificates → Key pair (public)
# Phải là public key ~87 ký tự, bắt đầu bằng B... KHÔNG dùng private key.
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
FIREBASE_VAPID_PUBLIC_KEY=

# Firebase Admin (server)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
FIREBASE_DATABASE_URL=

# App
NEXT_PUBLIC_URL=https://airanh.vercel.app
NEXT_PUBLIC_MAPBOX_TOKEN=

# Payments
SEPAY_API_TOKEN=
SEPAY_ACCOUNT_ID=
SEPAY_BANK_ACCOUNT_ID=
SEPAY_WEBHOOK_SECRET=
GHN_TOKEN=

# Email
RESEND_API_KEY=
